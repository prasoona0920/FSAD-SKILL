package com.example.library.controller;

import com.example.library.model.Book;
import org.springframework.web.bind.annotation.*;

import java.util.ArrayList;
import java.util.List;

@RestController
public class LibraryController {

    private List<Book> bookList = new ArrayList<>();

    // 1. /welcome
    @GetMapping("/welcome")
    public String welcome() {
        return "Welcome to the Online Library!";
    }

    // 2. /count
    @GetMapping("/count")
    public int countBooks() {
        return bookList.size();
    }

    // 3. /price
    @GetMapping("/price")
    public double bookPrice() {
        return 199.99;
    }

    // 4. /books - list of titles
    @GetMapping("/books")
    public List<String> listBooks() {
        List<String> titles = new ArrayList<>();
        for(Book b : bookList) titles.add(b.getTitle());
        return titles;
    }

    // 5. /books/{id} - book details
    @GetMapping("/books/{id}")
    public Book getBook(@PathVariable int id) {
        return bookList.stream().filter(b -> b.getId() == id).findFirst().orElse(null);
    }

    // 6. /search?title=...
    @GetMapping("/search")
    public String searchBook(@RequestParam String title) {
        return "Search requested for book: " + title;
    }

    // 7. /author/{name}
    @GetMapping("/author/{name}")
    public String authorInfo(@PathVariable String name) {
        return "Author details for: " + name;
    }

    // 8. /addbook - POST
    @PostMapping("/addbook")
    public String addBook(@RequestBody Book book) {
        bookList.add(book);
        return "Book added successfully: " + book.getTitle();
    }

    // 9. /viewbooks - GET all books
    @GetMapping("/viewbooks")
    public List<Book> viewBooks() {
        return bookList;
    }
}